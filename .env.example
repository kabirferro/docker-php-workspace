# Project paths
# Windows NTFS example:   WEB_DIR=C:/your-workspace/web
# WSL2 example:           WEB_DIR=//wsl.localhost/Ubuntu-24.04/home/your-workspace/web
DB_DIR=C:/your-workspace/database
VHOSTS_DIR=C:/your-workspace/vhosts
WEB_DIR=C:/your-workspace/web

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_PORT=3306

# phpMyAdmin
PMA_PORT=8080

# Redis
REDIS_PORT=6379

# Apache
APACHE_HTTP_PORT=80
APACHE_HTTPS_PORT=443
