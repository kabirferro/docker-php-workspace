# Project paths — defaults point to folders inside this repo.
# You can override them with any absolute path (use forward slashes on Windows).
DB_DIR=./mysql-data
VHOSTS_DIR=./vhosts
WEB_DIR=./web

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_PORT=3306

# phpMyAdmin
PMA_PORT=8080

# Redis
REDIS_PORT=6379

# Apache
APACHE_HTTP_PORT=80
APACHE_HTTPS_PORT=443
